# Model config
MODEL_PROVIDER=openai           # or "anthropic"
MODEL_NAME=gpt-4o               # or "claude-sonnet-4-6"
MODEL_MAX_TOKENS=4096
MODEL_TEMPERATURE=0.7

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...    # optional, only if MODEL_PROVIDER=anthropic

# Dev.to
DEVTO_API_KEY=...
DEVTO_CHALLENGE_URL=https://dev.to/challenges/ai   # set per challenge

# GitHub (auto-set in Actions, set manually for local runs)
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=glatinone/devto-challenge-agent
GITHUB_BRANCH=main
